# Server
NODE_ENV=development
PORT=4000

# Database — matches docker-compose.yml service
DATABASE_URL="postgresql://fms_user:fms_password@localhost:5432/fms_db?schema=public"
# JWT secrets — MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="df27d701972769acda7921f7efc286ac93c114ffbda0a60e09c2fc6b7d6b71e8"
JWT_REFRESH_SECRET="1323258fb7e4dcad646c2e9dfde05f9dc65022eacf4c0570c80c71c5cd3eb29a"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

# CORS - comma separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

COOKIE_DOMAIN=localhost
BCRYPT_SALT_ROUNDS=12
LOG_LEVEL=debug

# S3-compatible object storage (used from Phase 3 onward for POD/document uploads)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
